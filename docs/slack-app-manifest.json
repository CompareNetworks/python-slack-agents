{
  "_metadata": {
    "major_version": 2
  },
  "display_information": {
    "name": "** AGENT_NAME",
    "description": "** AGENT_DESCRIPTION",
    "background_color": "#000000"
  },
  "features": {
    "bot_user": {
      "display_name": "** agent-bot-name",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "** AGENT_DESCRIPTION",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "files:read",
        "files:write",
        "canvases:read",
        "canvases:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "assistant:write",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_started",
        "assistant_thread_context_changed",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "socket_mode_enabled": true
  }
}
